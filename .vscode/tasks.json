{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "FTC: Clean",
      "type": "shell",
      "command": ".\\gradlew.bat",
      "args": ["clean"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "FTC: Assemble Debug (TeamCode)",
      "type": "shell",
      "command": ".\\gradlew.bat",
      "args": [":TeamCode:assembleDebug"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "FTC: Install Debug (TeamCode)",
      "type": "shell",
      "command": ".\\gradlew.bat",
      "args": [":TeamCode:installDebug"],
      "problemMatcher": []
    },
    {
      "label": "FTC: Build + Install Debug (TeamCode)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "FTC: Assemble Debug (TeamCode)",
        "FTC: Install Debug (TeamCode)"
      ],
      "problemMatcher": []
    },
    {
      "label": "FTC: ADB Devices",
      "type": "shell",
      "command": "adb",
      "args": ["devices"],
      "problemMatcher": []
    },
    {
      "label": "FTC: Logcat (RobotController)",
      "type": "shell",
      "command": "adb",
      "args": [
        "logcat",
        "-s",
        "RobotCore:D",
        "UsbManager:D",
        "FtcRobotController:D",
        "*:S"
      ],
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
